{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "clean": "rm -rf dist",
    "migration:generate": "typeorm migration:generate -d ./data-source.ts",
    "migration:run": "typeorm migration:run -d ./data-source.ts",
    "migration:revert": "typeorm migration:revert -d ./data-source.ts"
  },
  "dependencies": {
    "@campus/shared": "workspace:*",
    "@clerk/backend": "^3.2.3",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.18",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@campus/eslint-config": "workspace:*",
    "@campus/typescript-config": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
